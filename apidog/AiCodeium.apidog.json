    "projectTestCaseTags": [
        {
            "id": 5590563,
            "name": "Required Fields Only",
            "description": "Send only the required fields with valid values, omitting all optional fields, to test minimal valid requests."
        },
        {
            "id": 5590564,
            "name": "Valid Semantic",
            "description": "Use values that are syntactically correct and also make sense in the business logic or domain context."
        },
        {
            "id": 5590565,
            "name": "Enum Combination Coverage",
            "description": "For all enum-type parameters, apply orthogonal design to systematically construct test case combinations of parameters and their enum values, dedicated to testing enum coverage."
        },
        {
            "id": 5590566,
            "name": "Other Positive Case",
            "description": "Provide realistic and valid inputs that match the API specification, producing the correct and expected result."
        },
        {
            "id": 5590567,
            "name": "Missing Required Fields",
            "description": "Omit one or more required fields in the request body or parameters."
        },
        {
            "id": 5590568,
            "name": "Invalid Values",
            "description": "Provide values that are within the correct type and format, but logically invalid for the field."
        },
        {
            "id": 5590569,
            "name": "Type Errors",
            "description": "Use values with incorrect data types, such as sending a string instead of an integer."
        },
        {
            "id": 5590570,
            "name": "Format Errors",
            "description": "Provide values in an incorrect format, e.g., wrong date pattern, malformed email address."
        },
        {
            "id": 5590571,
            "name": "Semantic Errors",
            "description": "Use syntactically correct and properly formatted values that are logically impossible or violate domain rules."
        },
        {
            "id": 5590572,
            "name": "Other Negative Case",
            "description": "Provide invalid or unexpected inputs that should trigger error handling or rejection by the API."
        },
        {
            "id": 5590573,
            "name": "Null",
            "description": "Must be the JSON literal `null` (not empty, not \"null\")."
        },
        {
            "id": 5590574,
            "name": "Zero",
            "description": "Must be the numeric literal 0."
        },
        {
            "id": 5590575,
            "name": "Empty Values",
            "description": "Must be \"\"."
        },
        {
            "id": 5590576,
            "name": "Max Values",
            "description": "Provide the exact minimum and maximum allowed values for numeric or date fields."
        },
        {
            "id": 5590577,
            "name": "Min Values",
            "description": "Provide the exact minimum and maximum allowed values for numeric or date fields."
        },
        {
            "id": 5590578,
            "name": "Overflow",
            "description": "Provide values just beyond the allowed minimum or maximum boundaries."
        },
        {
            "id": 5590579,
            "name": "Underflow",
            "description": "Provide values just beyond the allowed minimum or maximum boundaries."
        },
        {
            "id": 5590580,
            "name": "Overly Long Strings",
            "description": "Provide strings longer than the maximum allowed length, or shorter than the minimum required length."
        },
        {
            "id": 5590581,
            "name": "Overly Short Strings",
            "description": "Provide strings longer than the maximum allowed length, or shorter than the minimum required length."
        },
        {
            "id": 5590582,
            "name": "Broken Object Level Authorization",
            "description": "Users access or manipulate data objects without proper authorization."
        },
        {
            "id": 5590583,
            "name": "Access Control",
            "description": "Restricting resources and actions users can access based on roles, permissions, or attributes."
        },
        {
